import matplotlib.pyplot as plt
import csv

times = []
entropy = []
fisher = []

# 1. Read the data generated by your C++ code
with open('entropy_data.csv', 'r') as file:
    reader = csv.reader(file)
    next(reader) # Skip the header row
    for row in reader:
        times.append(float(row[0]))
        entropy.append(float(row[1]))
        fisher.append(float(row[2]))

# 2. Calculate the Left-Hand Side: dH/dt (Rate of Entropy Change)
dHdt = [0.0] * len(entropy)
for i in range(1, len(entropy) - 1):
    # Central difference method for the derivative
    dHdt[i] = (entropy[i+1] - entropy[i-1]) / (times[i+1] - times[i-1])

# Fix the edges
dHdt[0] = (entropy[1] - entropy[0]) / (times[1] - times[0])
dHdt[-1] = (entropy[-1] - entropy[-2]) / (times[-1] - times[-2])

# 3. Plot the Results
plt.figure(figsize=(10, 6))

# The Numerical Truth (Blue Line)
plt.plot(times, dHdt, label='Numerical dH/dt (Left Hand Side)', color='blue', linewidth=4, alpha=0.6)

# The Theoretical Equation (Red Dashed Line)
plt.plot(times, fisher, label='Fisher Information (Right Hand Side)', color='red', linestyle='dashed', linewidth=2)

plt.title('Theoretical Validation: Entropy Rate vs Fisher Information')
plt.xlabel('Time (s)')
plt.ylabel('Rate of Entropy Production')
plt.legend()
plt.grid(True)
plt.tight_layout()

plt.show()
