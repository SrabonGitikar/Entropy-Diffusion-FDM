import pandas as pd
import matplotlib.pyplot as plt

def generate_plot():
    # 1. Load the data generated by the C++ FDM simulation
    try:
        data = pd.read_csv('entropy_data_adv.csv')
    except FileNotFoundError:
        print("Error: 'entropy_data.csv' not found. Please ensure it is in the same directory.")
        return

    # Extract columns
    time = data['Time']
    dh_dt_num = data['dH_dt_Numerical']
    rhs_theoretical = data['RHS_Theoretical']

    # 2. Set up the plot aesthetics
    plt.figure(figsize=(10, 6))
    
    # Plot the numerical Left-Hand Side (Solid line)
    plt.plot(time, dh_dt_num, 
             label='Numerical dH/dt (Left-Hand Side)', 
             color='royalblue', 
             linewidth=2.5, 
             linestyle='-')
             
    # Plot the theoretical Right-Hand Side (Dashed line)
    plt.plot(time, rhs_theoretical, 
             label='Theoretical Source + Sink (Right-Hand Side)', 
             color='firebrick', 
             linewidth=2.5, 
             linestyle='--')

    # 3. Add labels, title, and formatting
    plt.title('Theoretical Validation: Entropy Rate in Compressive Flow', fontsize=14, pad=15)
    plt.xlabel('Time (s)', fontsize=12)
    plt.ylabel('Rate of Entropy Change (dH/dt)', fontsize=12)
    
    # Configure axes and grid
    plt.grid(True, which='both', linestyle=':', linewidth=1.0, alpha=0.7)
    plt.axhline(0, color='black', linewidth=1.0) # Adds a distinct line at y=0
    plt.xlim(0, max(time))
    
    # Add legend
    plt.legend(loc='upper right', fontsize=11, framealpha=0.9)

    # 4. Save and show the plot
    output_filename = 'entropy_rate_compressive_flow.png'
    plt.savefig(output_filename, dpi=300, bbox_inches='tight')
    print(f"Plot successfully generated and saved as '{output_filename}'")
    
    plt.show()

if __name__ == "__main__":
    generate_plot()
